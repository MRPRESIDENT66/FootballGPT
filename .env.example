DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
CHAT_MODEL=qwen3.5-plus
EMBEDDING_MODEL=text-embedding-v4

# API-Football (https://dashboard.api-football.com/ or RapidAPI)
# Free tier: 100 requests/day. Leave empty to use local data.
FOOTBALL_API_KEY=

# LangSmith Tracing (optional — https://smith.langchain.com)
# Free tier: 5,000 traces/month. Get API key from LangSmith dashboard.
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=FootballGPT
# EU region users: uncomment the line below
# LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com
